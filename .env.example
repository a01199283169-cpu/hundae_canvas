# 모닝프레임 환경변수 예시 (복사 후 .env 로 저장)

# 실행 환경: development | production
MONING_ENV=development

# SQLite (로컬 기본). 클라우드 DB 전환 시 Supabase Postgres URL 사용
DATABASE_URL=sqlite:///data/orders.db
# DATABASE_URL=postgresql://user:pass@host:5432/moning_prm

# 업로드 이미지 저장 경로 (클라우드: Supabase Storage 연동 전 로컬 경로)
MONING_UPLOAD_DIR=output/images/uploads

# Netlify 등 프론트 분리 배포 시 FastAPI 서버 URL
# MONING_API_URL=https://moning-prm-api.onrender.com

# 웹 서버 포트 (로컬)
PORT=8080
