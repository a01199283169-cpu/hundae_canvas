# 현대캔버스(모닝프레임) 환경변수 — .env 로 복사 후 사용

MONING_ENV=development

# --- 로컬: SQLite ---
DATABASE_URL=sqlite:///data/orders.db

# --- Render + Supabase: Postgres (Supabase → Settings → Database → Connection string → URI) ---
# Transaction pooler(6543) 또는 Direct(5432). Render에서는 pooler 권장.
# DATABASE_URL=postgresql://postgres.xxxx:YOUR_PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require

MONING_UPLOAD_DIR=output/images/uploads

# Render 배포 시 업로드 경로 (Persistent Disk)
# MONING_UPLOAD_DIR=/data/uploads

PORT=8080
